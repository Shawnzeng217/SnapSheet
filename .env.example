# =========================
# App Settings
# =========================
APP_ENV=development
APP_PORT=8000
APP_HOST=0.0.0.0

# =========================
# OCR Provider (glm / textin / abbyy / azure)
# =========================
OCR_PROVIDER=glm

# ABBYY Cloud OCR
ABBYY_APP_ID=
ABBYY_PASSWORD=
ABBYY_SERVICE_URL=https://cloud-westus.ocrsdk.com

# 合合信息 TextIn
TEXTIN_APP_ID=
TEXTIN_APP_SECRET=

# 智谱GLM-OCR
GLM_API_KEY=

# Azure Document Intelligence
AZURE_DOC_ENDPOINT=
AZURE_DOC_KEY=

# =========================
# Email (SMTP)
# =========================
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# =========================
# SharePoint (optional, phase 2)
# =========================
SHAREPOINT_SITE_URL=
SHAREPOINT_CLIENT_ID=
SHAREPOINT_CLIENT_SECRET=
SHAREPOINT_TENANT_ID=
